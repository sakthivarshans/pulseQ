# =============================================================================
# NeuralOps — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & Environment
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.key
*.pem
*.p12
secrets/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
.Python

# uv
.uv/
uv.lock           # optional: commit if you want reproducible installs

# Build / dist
build/
dist/
*.egg-info/
.eggs/

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# ML — Model Binaries & Training Artifacts
# (large binary files; store with DVC / Git LFS instead)
# -----------------------------------------------------------------------------
models/*.pkl
models/*.joblib
models/*.pt
models/*.h5
models/*.onnx
models/*.bin
models/simulation_results.json
models/conversation_analysis.json

# Training datasets (can be large)
training/*.csv
training/data/

# -----------------------------------------------------------------------------
# Node / Frontend
# -----------------------------------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/
frontend/*.local

# Logs from npm/yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Keep docker-compose.yml and Dockerfiles tracked.
# Ignore any local override files.
docker-compose.override.yml
docker-compose.local.yml

# -----------------------------------------------------------------------------
# Kubernetes / Helm
# -----------------------------------------------------------------------------
helm/charts/*.tgz

# -----------------------------------------------------------------------------
# Databases & Persistent Volumes (local dev)
# -----------------------------------------------------------------------------
*.sqlite3
*.db
postgres_data/
chroma_data/
chromadb/
redis_data/

# -----------------------------------------------------------------------------
# Logs & Telemetry
# -----------------------------------------------------------------------------
*.log
logs/
log/

# -----------------------------------------------------------------------------
# IDEs & OS
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
.cache/

# ╔════════════════════════════════════════════════════════════╗
# ║          NeuralOps — Environment Configuration             ║
# ║  Copy this to .env and fill in all required values         ║
# ╚════════════════════════════════════════════════════════════╝

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=neuralops
POSTGRES_USER=neuralops
POSTGRES_PASSWORD=your_strong_postgres_password_here
DATABASE_URL=postgresql+asyncpg://neuralops:your_strong_postgres_password_here@localhost:5432/neuralops

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_strong_redis_password_here
REDIS_URL=redis://:your_strong_redis_password_here@localhost:6379/0

# Redis Stream channels (do not change unless you update all consumers)
REDIS_STREAM_RAW_EVENTS=intelligence.events.raw
REDIS_STREAM_ANOMALY_EVENTS=intelligence.events.anomaly
REDIS_STREAM_INCIDENTS=intelligence.incidents
REDIS_CONSUMER_GROUP=neuralops-consumers

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Authentication credentials for the MongoDB container
MONGO_USER=neuralops
MONGO_PASSWORD=neuralops123
# Full connection URL (used by the Motor async client in the API service)
MONGODB_URL=mongodb://neuralops:neuralops123@mongodb:27017/neuralops?authSource=admin
MONGDB_DB_NAME=neuralops

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMADB_HOST=localhost
CHROMADB_PORT=8100
CHROMADB_COLLECTION_INCIDENTS=neuralops_incidents
CHROMADB_COLLECTION_RUNBOOKS=neuralops_runbooks

# ── LLM — OpenRouter (Primary) ───────────────────────────────────────────────
# Get a free API key at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1


# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-64-character-random-hex-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
API_LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,https://your-production-domain.com
API_RATE_LIMIT_PER_MINUTE=120

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_BASE_URL=ws://localhost:8080

# ── Module Ports ──────────────────────────────────────────────────────────────
INGESTION_PORT=8010
ML_ENGINE_PORT=8020
ORCHESTRATOR_PORT=8030
RCA_ENGINE_PORT=8040
ACTION_EXECUTOR_PORT=8050
MEMORY_PORT=8060
CHATBOT_PORT=8070

# ── ML Engine ─────────────────────────────────────────────────────────────────
# Anomaly scoring thresholds
ANOMALY_SCORE_WARN=0.60
ANOMALY_SCORE_CRITICAL=0.80
ISOLATION_FOREST_CONTAMINATION=0.05

# LSTM model settings
LSTM_SEQUENCE_LENGTH=60
LSTM_HIDDEN_SIZE=64
LSTM_NUM_LAYERS=2
LSTM_DROPOUT=0.2

# Auto-execution confidence threshold (below this needs human approval)
AUTO_EXECUTION_CONFIDENCE_THRESHOLD=0.85

# Ingestion polling interval in seconds
CONNECTOR_POLL_INTERVAL_SECONDS=60

# ── Model Artifacts ───────────────────────────────────────────────────────────
MODELS_DIR=/app/models
LSTM_MODEL_PATH=/app/models/lstm_anomaly_v1.pt
ISOLATION_FOREST_MODEL_PATH=/app/models/isolation_forest_v1.joblib
PROPHET_MODELS_DIR=/app/models/prophet

# ── Retraining ────────────────────────────────────────────────────────────────
RETRAINING_SCHEDULE_CRON=0 2 * * 0
RETRAINING_MIN_F1_THRESHOLD=0.80
RETRAINING_LOOKBACK_DAYS=7

# ── AWS Connector ─────────────────────────────────────────────────────────────
AWS_ENABLED=false
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1
AWS_CLOUDWATCH_LOG_GROUP=/neuralops/monitored-services
AWS_COST_EXPLORER_LOOKBACK_DAYS=7

# ── Azure Connector ───────────────────────────────────────────────────────────
AZURE_ENABLED=false
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id
AZURE_RESOURCE_GROUP=your_resource_group

# ── GCP Connector ─────────────────────────────────────────────────────────────
GCP_ENABLED=false
GCP_PROJECT_ID=your_gcp_project_id
# Path to service account JSON key file (mounted as secret in k8s)
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa-key.json
GCP_BILLING_ACCOUNT_ID=your_billing_account_id

# ── PagerDuty Integration ─────────────────────────────────────────────────────
PAGERDUTY_ENABLED=false
PAGERDUTY_API_KEY=your_pagerduty_api_key
PAGERDUTY_SERVICE_KEY=your_pagerduty_service_key
PAGERDUTY_FROM_EMAIL=alerts@your-company.com

# ── Slack Integration ─────────────────────────────────────────────────────────
SLACK_ENABLED=false
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_ALERTS_CHANNEL=#neuralops-alerts
SLACK_CHATBOT_CHANNEL=#neuralops-chatbot

# ── Jira Integration ──────────────────────────────────────────────────────────
JIRA_ENABLED=false
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_USER_EMAIL=your_jira_email@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=OPS
JIRA_INCIDENT_ISSUE_TYPE=Incident

# ── GitHub Integration ────────────────────────────────────────────────────────
GITHUB_ENABLED=false
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_ORG=your-github-org
GITHUB_MONITORED_REPOS=repo1,repo2,repo3

# ── GitLab Integration ────────────────────────────────────────────────────────
GITLAB_ENABLED=false
GITLAB_BASE_URL=https://gitlab.com
GITLAB_TOKEN=glpat-your_gitlab_access_token
GITLAB_GROUP_ID=your_gitlab_group_id

# ── Jenkins Integration ───────────────────────────────────────────────────────
JENKINS_ENABLED=false
JENKINS_BASE_URL=http://jenkins.your-company.com
JENKINS_USER=your_jenkins_user
JENKINS_API_TOKEN=your_jenkins_api_token

# ── Terraform Integration ─────────────────────────────────────────────────────
TERRAFORM_ENABLED=false
TERRAFORM_CLOUD_TOKEN=your_terraform_cloud_token
TERRAFORM_ORGANIZATION=your_tf_org
TERRAFORM_STATE_BACKEND_URL=https://app.terraform.io

# ── kubectl Integration ───────────────────────────────────────────────────────
KUBECTL_ENABLED=false
# Path to kubeconfig (mounted in k8s via projected volume from ServiceAccount)
KUBECONFIG_PATH=/root/.kube/config
KUBECTL_ALLOWED_NAMESPACES=default,production,staging
# Comma-separated allowlist — only these verbs+resources are permitted
KUBECTL_ACTION_ALLOWLIST=rollout restart,scale deployment,get pods,get nodes,describe pod,get events

# ── Ansible Integration ───────────────────────────────────────────────────────
ANSIBLE_ENABLED=false
ANSIBLE_PLAYBOOKS_DIR=/app/ansible/playbooks
ANSIBLE_INVENTORY_PATH=/app/ansible/inventory/hosts.ini
ANSIBLE_VAULT_PASSWORD_FILE=/secrets/ansible-vault-password

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=neuralops

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=
ENABLE_PROMETHEUS_METRICS=true
